# Discord bot token (from the Discord Developer Portal)
TOKEN=your-bot-token-here

# Application (client) ID of your Discord bot
CLIENT_ID=your-client-id-here

# Optional: register slash commands to a single guild for instant updates.
# Leave blank to register commands globally (can take up to 1 hour to propagate).
GUILD_ID=

# Optional: channel where the bot posts LFG listings
LFG_CHANNEL_ID=

# Optional: role granted extra permissions in created channels (e.g. sherpas)
SHERPA_ROLE_ID=

# Optional: comma-separated role IDs allowed to moderate any listing
ADMIN_ROLE_IDS=

# Set to "true" for verbose debug logging
DEBUG=false
